<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="HyperVManagerTray.UI.AboutWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt" />
    </Window.SystemBackdrop>

    <Grid x:Name="Root">
        <StackPanel>

            <!-- ── Brand header ──────────────────────────────────────────────── -->
            <Border Padding="14,12,8,12">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                        <GradientStop Color="#0E2235" Offset="0"/>
                        <GradientStop Color="#0A1825" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Interlocking rings: teal/blue left, purple/indigo right, amber Z in moat -->
                    <Canvas Width="44" Height="40" Grid.Column="0" VerticalAlignment="Center">
                        <Ellipse Width="28" Height="28" Canvas.Left="0" Canvas.Top="6">
                            <Ellipse.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#27E0C8" Offset="0"/>
                                    <GradientStop Color="#11A9D6" Offset="1"/>
                                </LinearGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                        <Ellipse Width="28" Height="28" Canvas.Left="16" Canvas.Top="6" Opacity="0.88">
                            <Ellipse.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#7B8CFF" Offset="0"/>
                                    <GradientStop Color="#3F5BE0" Offset="1"/>
                                </LinearGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                        <TextBlock Text="Z" Canvas.Left="18" Canvas.Top="9"
                                   FontSize="12" FontWeight="Bold"
                                   Foreground="#D8A657"/>
                    </Canvas>

                    <!-- App name + version -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center"
                                Margin="10,0,0,0" Spacing="2">
                        <TextBlock Text="Hyper-V Manager Tray"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="White"/>
                        <TextBlock x:Name="VersionText" Text="v—"
                                   FontSize="11" Foreground="#80FFFFFF"/>
                    </StackPanel>

                    <!-- Close button -->
                    <Button x:Name="CloseBtn" Grid.Column="2"
                            Content="✕" Width="32" Height="32"
                            Padding="0" FontSize="11"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            Foreground="#80FFFFFF"
                            VerticalAlignment="Top"/>
                </Grid>
            </Border>

            <!-- ── Body (Mica backdrop) ───────────────────────────────────────── -->
            <StackPanel Padding="16,12,16,16" Spacing="10">

                <!-- Company name: teal→purple gradient text -->
                <TextBlock FontSize="12" FontWeight="SemiBold">
                    <TextBlock.Foreground>
                        <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                            <GradientStop Color="#27E0C8" Offset="0"/>
                            <GradientStop Color="#7B8CFF" Offset="1"/>
                        </LinearGradientBrush>
                    </TextBlock.Foreground>
                    ZeroZero Software
                </TextBlock>

                <!-- Description -->
                <TextBlock
                    Text="Automatically connects Hyper-V VMs to the right virtual switch when the host changes networks. Manage VM power and state directly from the system tray."
                    FontSize="11" TextWrapping="Wrap"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                <!-- View on GitHub | Check for Updates -->
                <Grid ColumnSpacing="8" Margin="0,2,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="GitHubBtn" Grid.Column="0"
                            Content="View on GitHub"
                            FontSize="11" HorizontalAlignment="Stretch"/>
                    <Button x:Name="UpdateBtn" Grid.Column="1"
                            Content="Check for Updates"
                            FontSize="11" HorizontalAlignment="Stretch"/>
                </Grid>

                <!-- Buy Me a Coffee -->
                <Button x:Name="BmacBtn"
                        Content="☕  Buy Me a Coffee"
                        FontSize="11" HorizontalAlignment="Stretch"/>

            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
