<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="HyperVManagerTray.UI.DashboardWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt" />
    </Window.SystemBackdrop>

    <Grid x:Name="Root" Padding="20,16,20,20">
        <Grid.Resources>
            <Style x:Key="SectionLabelStyle" TargetType="TextBlock">
                <Setter Property="FontSize"         Value="10"/>
                <Setter Property="FontWeight"       Value="SemiBold"/>
                <Setter Property="CharacterSpacing" Value="100"/>
                <Setter Property="Foreground"       Value="{ThemeResource TextFillColorTertiaryBrush}"/>
            </Style>
            <Style x:Key="RowLabelStyle" TargetType="TextBlock">
                <Setter Property="FontSize"          Value="10"/>
                <Setter Property="FontWeight"        Value="SemiBold"/>
                <Setter Property="Foreground"        Value="{ThemeResource TextFillColorTertiaryBrush}"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>
            <Style x:Key="RowValueStyle" TargetType="TextBlock">
                <Setter Property="FontSize"          Value="13"/>
                <Setter Property="Foreground"        Value="{ThemeResource TextFillColorPrimaryBrush}"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="TextWrapping"      Value="Wrap"/>
            </Style>
        </Grid.Resources>
        <StackPanel Spacing="14">

            <!-- Title -->
            <TextBlock Text="Hyper-V Manager"
                       FontSize="13" FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>

            <!-- HOST NETWORK card -->
            <StackPanel Spacing="6">
                <TextBlock Text="HOST NETWORK" Style="{StaticResource SectionLabelStyle}"/>
                <Border CornerRadius="6" Padding="10,8,10,8"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <Grid ColumnSpacing="10" RowSpacing="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="62"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Adapter" Style="{StaticResource RowLabelStyle}"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="AdapterText" Text="—" Style="{StaticResource RowValueStyle}"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="IP"      Style="{StaticResource RowLabelStyle}"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="IpText"      Text="—" Style="{StaticResource RowValueStyle}"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Gateway" Style="{StaticResource RowLabelStyle}"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="GatewayText" Text="—" Style="{StaticResource RowValueStyle}"/>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="DNS"     Style="{StaticResource RowLabelStyle}"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" x:Name="DnsText"     Text="—" Style="{StaticResource RowValueStyle}"/>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- VIRTUAL MACHINES section label + per-VM cards (built in code-behind) -->
            <StackPanel Spacing="6">
                <TextBlock Text="VIRTUAL MACHINES" Style="{StaticResource SectionLabelStyle}"/>
                <StackPanel x:Name="VmPanel" Spacing="8"/>
            </StackPanel>

        </StackPanel>
    </Grid>
</Window>
